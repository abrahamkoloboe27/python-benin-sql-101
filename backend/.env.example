# Variables d'environnement – copier ce fichier en .env et remplir les valeurs

# Port d'écoute du serveur
PORT=3001

# Secret pour signer les JWT (utiliser une chaîne longue et aléatoire en production)
JWT_SECRET=changez-moi-en-production-utilisez-une-longue-chaine-aleatoire

# URL(s) du frontend autorisées par CORS – plusieurs valeurs séparées par des virgules
# Exemple dev :  FRONTEND_URL=http://localhost:5173
# Exemple prod : FRONTEND_URL=https://abrahamkoloboe27.github.io,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Chemin vers le fichier SQLite (optionnel, défaut : ./data/users.db)
# DB_PATH=./data/users.db
