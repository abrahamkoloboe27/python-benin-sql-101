# Variables d'environnement – copier ce fichier en .env et remplir les valeurs

# Port d'écoute du serveur
PORT=3001

# Secret pour signer les JWT (utiliser une chaîne longue et aléatoire en production)
JWT_SECRET=changez-moi-en-production-utilisez-une-longue-chaine-aleatoire

# URL de connexion PostgreSQL Supabase
# Format : postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:mot-de-passe@db.xxxxx.supabase.co:5432/postgres
