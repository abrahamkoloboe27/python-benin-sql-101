# Variables d'environnement pour la connexion PostgreSQL
# Copiez ce fichier en .env et renseignez vos propres valeurs.
# Ne commitez jamais le fichier .env !

DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MODE=session
DB_SSLMODE=require

# Optionnel : schéma PostgreSQL (défaut : public)
DB_SCHEMA=public
